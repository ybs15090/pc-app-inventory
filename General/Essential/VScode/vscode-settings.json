    "TODO",
    "BUG",
    "tag",
    "done",
    "mark",
    "test",
    "XXX"
  ],
  "todo-tree.highlights.defaultHighlight": {
    "foreground": "#000000",
    "background": "#FFFF00",
    "icon": "check",
    "rulerColour": "#FFFF00",
    "type": "tag",
    "iconColour": "#FFFF00"
    },
  "todo-tree.highlights.customHighlight": {
